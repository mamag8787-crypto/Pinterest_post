# ── TELEGRAM ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=123456789
# Чистая ссылка — к каждому пину добавится ?ref=p{id} для уникального трекинга
TELEGRAM_CHANNEL_LINK=https://t.me/yourchannel

# ── PINTEREST ─────────────────────────────────────────────────────────────────
PINTEREST_EMAIL=your@email.com
PINTEREST_PASSWORD=your_pinterest_password
PINTEREST_BOARD_NAME=Название доски точно как на сайте
# Файл сессии — Railway: /data/pinterest_session.json
SESSION_FILE=/data/pinterest_session.json

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── РАСПИСАНИЕ ────────────────────────────────────────────────────────────────
POST_START_HOUR=9        # 9:00, 11:30, 14:00, 16:30, 19:00
POSTS_PER_DAY=5
POST_WINDOW_HOURS=10
TIMEZONE=Europe/Moscow

# ── РЕТРАЙ ────────────────────────────────────────────────────────────────────
MAX_RETRIES=3            # попыток перед mark_failed
RETRY_DELAY_MIN=60       # минут между попытками

# ── ОЧЕРЕДЬ ───────────────────────────────────────────────────────────────────
QUEUE_MAX=200
BATCH_TIMEOUT_SEC=300    # 5 минут тишины → итоговый отчёт о загрузке

# ── ХРАНИЛИЩЕ ─────────────────────────────────────────────────────────────────
# Railway: примонтируй Volume в /data и укажи /data/queue.db
DB_PATH=queue.db
# Логи (Railway: /data/logs)
LOG_DIR=logs
